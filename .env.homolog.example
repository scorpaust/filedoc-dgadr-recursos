# Modelo das variáveis exigidas pela stack de homologação
# (docker-compose.homolog.yml — Fase 5, Deployment). Documenta os NOMES das
# variáveis, nunca valores reais — ver docs/deploy-homologacao.md.
#
# Copiar para ".env.homolog" no anfitrião de homologação (nunca commitado —
# ver .gitignore), preenchido com segredos fortes e exclusivos deste
# ambiente (nunca reutilizados de desenvolvimento local nem de produção),
# geridos pelo mecanismo de segredos do anfitrião escolhido pela DGADR.
#
#   docker compose -f docker-compose.homolog.yml --env-file .env.homolog up -d

# --- Imagens a promover (Fase 4 — ghcr.io) ---------------------------------

# Tag exata já publicada por publish-images.yml para o commit/versão a
# promover (ex.: sha-1a2b3c4, ou vX.Y.Z). Nunca "latest" — a rastreabilidade
# do que está a correr em homologação depende de uma tag explícita.
IMAGE_TAG=

# Só sobrepor se as imagens não estiverem em ghcr.io/scorpaust/filedoc-*
# (ex.: outro owner/registo institucional).
# API_IMAGE=ghcr.io/scorpaust/filedoc-api
# WEB_IMAGE=ghcr.io/scorpaust/filedoc-web

# --- Rede -------------------------------------------------------------------

# Endereço do anfitrião a que os serviços ficam associados. Por omissão só
# o próprio anfitrião (127.0.0.1) — nunca exposto publicamente sem um
# proxy/domínio/TLS institucional confirmado à frente.
# BIND_ADDRESS=127.0.0.1

# Endereço da API alcançável a partir do browser do utilizador (não a rede
# interna do Docker) — ajustar quando existir um domínio de homologação.
# WEB_API_URL=http://localhost:3000/api/v1

# --- PostgreSQL ---------------------------------------------------------

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Armazenamento de objetos (MinIO) ---------------------------------------

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- Pendente: só quando a via de integração de funcionalidades implementar
# autenticação real e consumo de armazenamento na API -----------------------
#
# SESSION_SECRET, SESSION_TTL, ALLOWED_EMAIL_DOMAINS, STORAGE_ENDPOINT,
# STORAGE_REGION, STORAGE_BUCKET, STORAGE_ACCESS_KEY, STORAGE_SECRET_KEY,
# STORAGE_FORCE_PATH_STYLE, MAX_UPLOAD_SIZE, MAX_ATTACHMENTS_PER_TICKET,
# CORS_ALLOWED_ORIGINS, RETENTION_POLICY_DAYS — ver context/project-spec.md,
# secção "Variáveis de ambiente". A API ainda não lê nem valida estas
# variáveis (não fazem parte de apps/api/.env.example): acrescentar aqui e
# ao docker-compose.homolog.yml quando essas funcionalidades existirem, não
# antes — nunca preencher com um pressuposto.
