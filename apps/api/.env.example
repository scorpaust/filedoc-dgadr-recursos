# Ambiente da aplicação (development | production | test)
NODE_ENV=development

# Porta HTTP da API NestJS
PORT=3000

# Ligação ao PostgreSQL (ver docker-compose.yml na raiz do repositório).
# Porta 5433 no anfitrião — evita conflito com uma instância nativa de
# PostgreSQL já a ocupar a porta 5432 por omissão neste ambiente.
# A aplicação não arranca sem esta variável definida.
DATABASE_URL="postgresql://filedoc:filedoc@localhost:5433/filedoc?schema=public"
