# Ambiente dos testes de integração (Fase 2, BD — ver test/integration/).
NODE_ENV=test
PORT=3001

# Ligação ao PostgreSQL efémero de testes (ver docker-compose.yml, serviço "postgres-test",
# perfil "test"): docker compose --profile test up -d postgres-test
# Isolado da base de dados de desenvolvimento (porta 5433) — os testes de integração
# aplicam migrações e alteram dados livremente nesta base de dados.
DATABASE_URL="postgresql://filedoc_test:filedoc_test@localhost:5434/filedoc_test?schema=public"
